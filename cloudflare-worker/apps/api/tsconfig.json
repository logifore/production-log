{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "WebWorker"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "composite": true,
    "types": ["vitest/globals"]
  },
  "include": ["src", "../../packages/core/src"],
  "exclude": ["src/**/*.test.ts"]
}
